<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFollowUpHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/follow_up_header"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#2A2A2A" />

            <TextView
                android:id="@+id/tvFollowUpSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/follow_up_sub"
                android:textSize="13sp"
                android:textColor="#6F6F6F" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_preferences"
            android:contentDescription="Settings"
            app:tint="#555555" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/searchFilterContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerContainer"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etSearchLeads"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@android:drawable/edit_text"
            android:hint="Search names..."
            android:inputType="textPersonName"
            android:paddingHorizontal="12dp"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/btnFilterCategory"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:contentDescription="Filter Category"
            app:tint="#007BFF" />
    </LinearLayout>

    <ListView
        android:id="@+id/listViewFollowUps"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/searchFilterContainer"
        android:layout_above="@+id/bulkActionBar"
        android:layout_marginTop="12dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp" />

    <LinearLayout
        android:id="@+id/bulkActionBar"
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:visibility="gone"
        android:paddingTop="16dp">

        <Button
            android:id="@+id/btnBulkDelete"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Delete Selected"
            android:backgroundTint="#DC3545"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnCancelBulk"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="#555555" />

        <Button
            android:id="@+id/btnBulkSnooze"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_bulk_snooze"
            android:backgroundTint="#007BFF"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</RelativeLayout>
