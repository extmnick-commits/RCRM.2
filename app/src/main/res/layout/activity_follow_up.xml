<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvFollowUpHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/follow_up_header"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#2A2A2A" />

    <TextView
        android:id="@+id/tvFollowUpSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvFollowUpHeader"
        android:text="@string/follow_up_sub"
        android:textSize="13sp"
        android:textColor="#6F6F6F"
        android:layout_marginBottom="16dp" />

    <ListView
        android:id="@+id/listViewFollowUps"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tvFollowUpSub"
        android:layout_above="@+id/bulkActionBar"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp" />

    <LinearLayout
        android:id="@+id/bulkActionBar"
        style="?android:attr/buttonBarStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:visibility="gone"
        android:paddingTop="16dp">

        <Button
            android:id="@+id/btnBulkSnooze"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_bulk_snooze"
            android:backgroundTint="#007BFF"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</RelativeLayout>