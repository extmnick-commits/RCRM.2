<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_log_call"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:alpha="0.6" />

                <Button
                    android:id="@+id/btnScanCardSmartLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📷 Scan Business Card"
                    android:backgroundTint="@color/colorSecondary"
                    android:textColor="@color/white"
                    android:layout_marginTop="8dp"/>

                <EditText
                    android:id="@+id/etContactName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_contact_name"
                    android:inputType="textPersonName"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:background="@android:color/transparent"
                    android:paddingVertical="4dp"
                    android:importantForAutofill="no" />

                <TextView
                    android:id="@+id/tvLogPhoneNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textColorSecondary"
                    android:textSize="14sp"
                    tools:text="(555) 555-5555" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSkipPersonal"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="@string/btn_skip_personal"
                        android:textColor="@color/colorDanger"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp"
                        tools:ignore="TouchTargetSizeCheck" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnIgnoreCallLog"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="@string/btn_ignore_call_log"
                        android:textColor="@color/textColorSecondary"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp"
                        tools:ignore="TouchTargetSizeCheck" />
                </LinearLayout>
            </LinearLayout>

            <!-- Advanced Logging Toggle Header -->
            <LinearLayout
                android:id="@+id/headerAdvancedLogging"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp"
                android:layout_marginTop="4dp"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Advanced Details (Email, Address, Company, etc)"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvToggleAdvanced"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show ▼"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/containerAdvancedLogging"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etContactEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email Address"
                    android:inputType="textEmailAddress"
                    android:layout_marginTop="8dp"
                    android:importantForAutofill="no" />

                <EditText
                    android:id="@+id/etContactAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Address"
                    android:inputType="textPostalAddress"
                    android:layout_marginTop="8dp" />

                <EditText
                    android:id="@+id/etContactCompany"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Company"
                    android:inputType="textCapWords"
                    android:layout_marginTop="8dp"
                    android:importantForAutofill="no" />

                <EditText
                    android:id="@+id/etContactJobTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Job Title"
                    android:inputType="textCapWords"
                    android:layout_marginTop="8dp"
                    android:importantForAutofill="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/label_category"
                    android:textStyle="bold"
                    android:textColor="@color/textColorSecondary"
                    android:textSize="12sp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <CheckBox android:id="@+id/cbRecruit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/category_recruit" />
                    <CheckBox android:id="@+id/cbProspect" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/category_prospect" />
                    <CheckBox android:id="@+id/cbClient" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/category_client" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/clientSubCategoryLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:layout_marginStart="16dp">
                    <CheckBox android:id="@+id/cbInvestment" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Investment" />
                    <CheckBox android:id="@+id/cbLifeInsurance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Life Insurance" />
                </LinearLayout>
            </LinearLayout>

            <EditText
                android:id="@+id/etQuickNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_quick_note_example"
                android:inputType="textCapSentences"
                android:layout_marginTop="8dp"
                android:textSize="14sp"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/label_schedule_followup"
                android:textStyle="bold"
                android:textColor="@color/textColorSecondary"
                android:textSize="12sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">
                <Button android:id="@+id/btnPlus1Week" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/btn_1_week" style="?android:attr/buttonStyleSmall"/>
                <Button android:id="@+id/btnPlus2Weeks" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/btn_2_weeks" style="?android:attr/buttonStyleSmall"/>
                <Button android:id="@+id/btnPlus1Month" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="@string/btn_1_month" style="?android:attr/buttonStyleSmall"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">
                <Button
                    android:id="@+id/btn7pmToday"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_7pm_today"
                    android:backgroundTint="?attr/colorSurface"
                    android:textColor="@color/textColorPrimary"
                    android:textAllCaps="false"
                    style="?android:attr/buttonStyleSmall"/>
                <Button
                    android:id="@+id/btn7pmTomorrow"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/btn_7pm_tomorrow"
                    android:backgroundTint="?attr/colorSurface"
                    android:textColor="@color/textColorPrimary"
                    android:textAllCaps="false"
                    style="?android:attr/buttonStyleSmall"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnScheduleCustom"
                style="?android:attr/buttonStyleSmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:backgroundTint="?attr/colorSurface"
                android:text="Schedule"
                android:textAllCaps="false"
                android:textColor="@color/textColorPrimary" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dividerColor"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"/>

            <!-- SMS Intro Toggle Header -->
            <LinearLayout
                android:id="@+id/headerSmsIntro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp"
                android:background="?attr/selectableItemBackground">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Quick Intro SMS"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvToggleSms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show ▼"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/containerSmsIntro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvIntroTextLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="@string/label_quick_intro_sms"
                    android:textColor="@color/textColorSecondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnDefaultIntro"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_toStartOf="@id/btnManagePresets"
                    android:layout_centerVertical="true"
                    android:text="@string/btn_use_default"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:minWidth="0dp"
                    android:paddingHorizontal="8dp" />

                <Button
                    android:id="@+id/btnManagePresets"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/btn_presets_dropdown"
                    android:textColor="@color/colorPrimary"
                    android:textSize="12sp" />
            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/dividerColor"
                app:strokeWidth="1dp">

                <EditText
                    android:id="@+id/etIntroText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints="message"
                    android:background="@android:color/transparent"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minHeight="80dp"
                    android:padding="12dp"
                    android:textSize="14sp" />
            </com.google.android.material.card.MaterialCardView>

                <Button
                    android:id="@+id/btnSendIntroAction"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="?attr/colorSurface"
                    android:text="@string/btn_send_intro"
                    android:textColor="@color/colorPrimary"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bottomActionContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btnSaveLeadAction"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:backgroundTint="@color/colorPrimary"
                    android:text="@string/btn_save_lead"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>