<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <EditText
            android:id="@+id/editDetailName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_prospect_name"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#2A2A2A"
            android:autofillHints="name"
            android:inputType="textPersonName" />

        <EditText
            android:id="@+id/editDetailPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_phone_number"
            android:autofillHints="phone"
            android:inputType="phone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Category"
            android:textStyle="bold"
            android:textColor="#555555"
            android:textSize="12sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <CheckBox android:id="@+id/cbRecruitDetail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/category_recruit" />
            <CheckBox android:id="@+id/cbProspectDetail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/category_prospect" />
            <CheckBox android:id="@+id/cbClientDetail" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/category_client" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Internal Notes"
                android:textColor="#555555"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnAddDatedNote"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/btn_add_dated_note"
                android:textSize="12sp"
                android:backgroundTint="#E0F0FF"
                android:textColor="#007BFF" />
        </LinearLayout>

        <!-- Container for notes list -->
        <LinearLayout
            android:id="@+id/notesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnSetReminder"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_set_reminder"
            android:backgroundTint="#F0F2F5"
            android:textColor="#2A2A2A" />

        <Button
            android:id="@+id/btnAddCalendar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/btn_add_calendar"
            android:backgroundTint="#F0F2F5"
            android:textColor="#2A2A2A" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvIntroTextLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="@string/label_quick_intro_sms"
                android:textColor="#555555"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnDefaultIntro"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_toStartOf="@id/btnManagePresets"
                android:layout_centerVertical="true"
                android:text="@string/btn_use_default"
                android:textColor="#007BFF"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:minWidth="0dp"
                android:paddingHorizontal="8dp" />

            <Button
                android:id="@+id/btnManagePresets"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text="@string/btn_presets_dropdown"
                android:textColor="#007BFF"
                android:textSize="12sp" />
        </RelativeLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="#DDDDDD"
            app:strokeWidth="1dp">

            <EditText
                android:id="@+id/etIntroText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="message"
                android:background="@android:color/transparent"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:minHeight="80dp"
                android:padding="12dp"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnSendIntroAction"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#FFFFFF"
            android:text="@string/btn_send_intro"
            android:textColor="#007BFF"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnSaveChanges"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:text="Save &amp; Mark Followed Up"
            android:backgroundTint="#007BFF"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>
