<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings &amp; Presets"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2A2A2A"
            android:layout_marginBottom="16dp"/>

        <!-- Maintenance Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MAINTENANCE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#555555"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnCleanDuplicates"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clean &amp; Merge"
                android:textSize="11sp"
                android:backgroundTint="#007BFF"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnBulkDeleteContacts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Multi-Delete"
                android:textSize="11sp"
                android:backgroundTint="#F44336"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="24dp"/>

        <!-- Presets Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage SMS Presets"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#2A2A2A"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etNewPreset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="New message preset..."
            android:inputType="textMultiLine"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnInsertNameTagDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Insert [NAME] Tag"
            android:textSize="12sp"
            android:backgroundTint="#6C757D"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnDefaultFollowUp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/btn_use_system_default"
                android:textSize="11sp"
                android:backgroundTint="#E0F0FF"
                android:textColor="#007BFF"
                android:textAllCaps="false"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnSetAccountDefault"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/btn_save_account_default"
                android:textSize="11sp"
                android:backgroundTint="#28A745"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnAddPreset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_save_to_presets"
            android:backgroundTint="#6C757D"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:layout_marginBottom="16dp"/>

        <ListView
            android:id="@+id/listViewPresets"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
