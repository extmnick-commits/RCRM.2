<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/card_background"
    android:elevation="2dp">

    <TextView
        android:id="@+id/tvSideKickLeadName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lead Name"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"/>

    <TextView
        android:id="@+id/tvSideKickSuggestion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="This is the AI's suggestion for what to do next with this lead."
        android:layout_marginTop="8dp"
        android:textSize="16sp"
        android:textColor="?android:attr/textColorSecondary"/>

    <TextView
        android:id="@+id/tvSideKickCoachedAt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Suggested 5 minutes ago"
        android:layout_marginTop="12dp"
        android:textSize="12sp"
        android:textStyle="italic"
        android:textColor="?android:attr/textColorTertiary"/>

</LinearLayout>